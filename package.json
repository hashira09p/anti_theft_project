{
  "name": "rfid-dashboard",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev -- --host 0.0.0.0 --port 3000",
    "build": "npm --prefix client run build"
  },
  "dependencies": {
    "concurrently": "^8.0.1",
    "cors": "^2.8.0",
    "express": "^4.19.0"
  }
}
